{
  "manifest_version": 3,
  "name": "SherlockMate",
  "version": "2.0.0",
  "description": "Real-time chess analysis. Top 3 best moves instantly.",

  "permissions": ["storage"],

  "host_permissions": [
    "https://www.chess.com/*",
    "https://lichess.org/*",
    "https://api.groq.com/*"
  ],
    "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*",
        "https://lichess.org/*"
      ],
      "js": ["content/inject.js"],
      "css": ["ui/panel.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
